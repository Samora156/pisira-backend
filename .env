# Konfigurasi Aplikasi PISIRA
APP_PORT=8080
APP_ENV=development

# Database Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgre
DB_NAME=pisira_db

# JWT Secret (ganti dengan string acak yang panjang)
JWT_SECRET=pisira_secret_key_ganti_ini_dengan_random_string_panjang
JWT_EXPIRE_HOURS=24
